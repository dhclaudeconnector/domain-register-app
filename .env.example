# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Encryption salt (random string >= 32 chars)
NEXT_PUBLIC_ENCRYPT_SALT=

# Admin/deploy scripts only. Keep the JSON outside git.
FIREBASE_SERVICE_ACCOUNT_PATH=-gitignore/domain-register-app-demo-firebase-adminsdk-fbsvc-698c709985.json
FIREBASE_CONFIG_APP_PATH=-gitignore/firebaseConfig-app.json
FIREBASE_REGION=asia-southeast1

# HTTP client test variables (.http files read these through {{$dotenv VAR_NAME}})
NEXT_PUBLIC_APP_URL=http://localhost:3000
DPDNS_TEST_TOKEN=
DPDNS_TEST_DOMAIN=myapp.dpdns.org
DPDNS_TEST_SLOT_TYPE=free
DPDNS_TEST_NS1=anna.ns.cloudflare.com
DPDNS_TEST_NS2=bob.ns.cloudflare.com
CLOUDFLARE_TEST_EMAIL=
CLOUDFLARE_TEST_API_KEY=
CLOUDFLARE_TEST_ACCOUNT_ID=
CLOUDFLARE_TEST_ZONE_NAME=myapp.dpdns.org
CLOUDFLARE_TEST_ZONE_ID=
