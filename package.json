{
  "name": "domain-register-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke-test.mjs",
    "firebase:env": "node scripts/setup.firebaseEnv.mjs",
    "firebase:env:force": "node scripts/setup.firebaseEnv.mjs --force",
    "firebase:check": "node scripts/deploy.checkFirebase.mjs",
    "firebase:rules": "node scripts/deploy.setRule.mjs",
    "deploy:prep": "npm run firebase:check && npm run firebase:rules",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "latest",
    "@radix-ui/react-slot": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "crypto-js": "latest",
    "firebase": "latest",
    "lucide-react": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-hook-form": "latest",
    "tailwind-merge": "latest",
    "tailwindcss-animate": "latest",
    "zod": "latest",
    "zustand": "latest"
  },
  "devDependencies": {
    "@types/crypto-js": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "tailwindcss": "latest",
    "@tailwindcss/postcss": "latest",
    "typescript": "latest",
    "vitest": "latest",
    "@vitest/coverage-v8": "latest",
    "@vitejs/plugin-react": "latest",
    "vite-tsconfig-paths": "latest",
    "jsdom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/user-event": "latest",
    "@testing-library/dom": "latest",
    "@vitest/ui": "latest"
  }
}
