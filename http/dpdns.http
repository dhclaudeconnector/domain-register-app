@dpdnsBaseUrl = https://domain-api.digitalplat.org/api/v1
@appBaseUrl = {{$dotenv NEXT_PUBLIC_APP_URL}}
@dpdnsToken = {{$dotenv DPDNS_TEST_TOKEN}}
@testDomain = {{$dotenv DPDNS_TEST_DOMAIN}}
@slotType = {{$dotenv DPDNS_TEST_SLOT_TYPE}}
@ns1 = {{$dotenv DPDNS_TEST_NS1}}
@ns2 = {{$dotenv DPDNS_TEST_NS2}}

### DPDNS · List domains (direct)
GET {{dpdnsBaseUrl}}/domains
Authorization: Bearer {{dpdnsToken}}
Content-Type: application/json

### DPDNS · Register domain (direct)
POST {{dpdnsBaseUrl}}/domains
Authorization: Bearer {{dpdnsToken}}
Content-Type: application/json

{
  "domain": "{{testDomain}}",
  "slot_type": "{{slotType}}",
  "nameservers": ["{{ns1}}", "{{ns2}}"]
}

### DPDNS · Update nameservers (direct)
PATCH {{dpdnsBaseUrl}}/domains/{{testDomain}}/nameservers
Authorization: Bearer {{dpdnsToken}}
Content-Type: application/json

{
  "nameservers": ["{{ns1}}", "{{ns2}}"]
}

### DPDNS · Delete domain (direct) — destructive, pendingdelete for 7 days
DELETE {{dpdnsBaseUrl}}/domains/{{testDomain}}
Authorization: Bearer {{dpdnsToken}}
Content-Type: application/json

### DPDNS proxy · List domains through Next.js route
POST {{appBaseUrl}}/api/proxy/dpdns
Content-Type: application/json

{
  "endpoint": "/api/v1/domains",
  "method": "GET",
  "token": "{{dpdnsToken}}"
}

### DPDNS proxy · Register domain through Next.js route
POST {{appBaseUrl}}/api/proxy/dpdns
Content-Type: application/json

{
  "endpoint": "/api/v1/domains",
  "method": "POST",
  "token": "{{dpdnsToken}}",
  "body": {
    "domain": "{{testDomain}}",
    "slot_type": "{{slotType}}",
    "nameservers": ["{{ns1}}", "{{ns2}}"]
  }
}

### DPDNS proxy · Update nameservers through Next.js route
POST {{appBaseUrl}}/api/proxy/dpdns
Content-Type: application/json

{
  "endpoint": "/api/v1/domains/{{testDomain}}/nameservers",
  "method": "PATCH",
  "token": "{{dpdnsToken}}",
  "body": {
    "nameservers": ["{{ns1}}", "{{ns2}}"]
  }
}

### DPDNS proxy · Delete domain through Next.js route — destructive, pendingdelete for 7 days
POST {{appBaseUrl}}/api/proxy/dpdns
Content-Type: application/json

{
  "endpoint": "/api/v1/domains/{{testDomain}}",
  "method": "DELETE",
  "token": "{{dpdnsToken}}"
}
